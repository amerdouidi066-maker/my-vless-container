{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": "REPLACE_PORT",
      "protocol": "vless",
      "settings": {
        "clients": [
          { "id": "REPLACE_UUID", "email": "user@example.com" }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "REPLACE_PATH"
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ]
}
